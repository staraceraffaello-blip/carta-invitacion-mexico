# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email delivery)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Carta de Invitación <cartas@cartadeinvitacionmexico.com>

# Anthropic (letter polish with Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Site URL (fallback for Stripe redirect URLs)
SITE_URL=https://cartadeinvitacionmexico.com

# Google Search Console MCP (OAuth2)
# Crear credenciales en: https://console.cloud.google.com → APIs & Services → Credentials
# Habilitar: Google Search Console API y Google Analytics Data API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/oauth/callback
