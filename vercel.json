{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/openapi.json",
      "destination": "/api/v1/openapi.js"
    },
    {
      "source": "/api/submit",
      "destination": "/api/submit.js"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook.js"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/agent.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/openapi.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog/carta-invitacion-mexico",
      "destination": "/articulos/carta-invitacion-mexico",
      "statusCode": 301
    },
    {
      "source": "/blog/carta-invitacion-mexico-venezolanos",
      "destination": "/articulos/carta-invitacion-mexico-venezolanos",
      "statusCode": 301
    },
    {
      "source": "/blog/documentos-migracion-mexico",
      "destination": "/articulos/documentos-migracion-mexico",
      "statusCode": 301
    },
    {
      "source": "/blog/:path*",
      "destination": "/articulos",
      "statusCode": 301
    }
  ]
}
