{
  "dangerouslySkipPermissions": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "grep -rn 'favicon' *.html | grep -v 'logo-simple.png' && echo 'WARNING: Unexpected favicon reference found' || true",
            "timeout": 30,
            "statusMessage": "Checking favicon consistency..."
          }
        ]
      }
    ]
  }
}
